{
  "expo": {
    "name": "Tignan",
    "slug": "tignan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/spash_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/spash_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Needed for SOS"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/spash_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/spash_logo.png"
    },
    "plugins": ["expo-location"]
  }
}
