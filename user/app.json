{
  "expo": {
    "name": "Tignan",
    "slug": "tignan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/spash_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/spash_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Needed for SOS"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/spash_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.semicolon.tignan"
    },
    "web": {
      "favicon": "./assets/spash_logo.png"
    },
    "plugins": [
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "bced787d-bef2-4bd7-9bda-ea12ab46329e"
      }
    }
  }
}
